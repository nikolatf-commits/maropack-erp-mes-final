# MAROPACK ERP/MES - ENV TEMPLATE
# Kopiraj kao .env.local za lokalni rad. Ne šalji .env na GitHub.

VITE_APP_NAME=MAROPACK ERP/MES
VITE_APP_ENV=development

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Opcionalno za AI module ako koristiš direktno iz frontenda.
# Bolje: koristi serverless API rutu da ključ ne bude javno izložen.
VITE_GEMINI_API_KEY=

# Opcionalno
VITE_ENABLE_LOCAL_FALLBACK=true
VITE_ENABLE_AI_FALLBACK=true
